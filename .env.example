# =============================================================================
# Sales Context Agent - Configuration
# =============================================================================
# This demo generates pre-meeting briefs by searching across Notion, Google
# Drive, GitHub, and other sources via Airweave.
#
# QUICK START (minimal config):
#   1. Copy this file to .env
#   2. Optionally add ANTHROPIC_API_KEY for smarter decomposition/synthesis
#   3. Run the demo! (works with sample data by default)
#
# Everything is optional -- the demo works with sample data out of the box.
# =============================================================================

# =============================================================================
# Airweave Configuration
# =============================================================================
# Sign up at https://airweave.ai to get your API key.
# Create a collection and connect your data sources (Notion, Google Drive,
# GitHub, Slack, etc.)

AIRWEAVE_API_KEY=your_airweave_api_key
AIRWEAVE_API_URL=https://api.airweave.ai
AIRWEAVE_COLLECTION_ID=your_collection_id

# =============================================================================
# LLM Provider (choose one)
# =============================================================================
# Used for query decomposition and brief synthesis.

# Option 1: Anthropic (recommended)
ANTHROPIC_API_KEY=your_anthropic_api_key
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Option 2: OpenAI
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_MODEL=gpt-4o

# =============================================================================
# OPTIONAL: Slack Integration
# =============================================================================
# Enable to post generated briefs to a Slack channel.
# Set SLACK_ENABLED=true and provide credentials.
#
# Create a Slack app at https://api.slack.com/apps with:
# - chat:write permission
# - Bot token (xoxb-...)

# SLACK_ENABLED=false
# SLACK_BOT_TOKEN=xoxb-your-bot-token
# SLACK_CHANNEL_ID=C0123456789
